# =========================================================================
# DOMINOSFIRE ENVIRONMENT VARIABLES REFERENCE
# =========================================================================

# -------------------------------------------------------------------------
# 1. Gemini AI API
# -------------------------------------------------------------------------
# Description: Required for generating live, personalized Dominican commentary
#              during the game. If not provided, the server falls back to an
#              intelligent, context-aware local phrases engine.
# Mandatory: Optional (has automatic fallback)
GEMINI_API_KEY="your-gemini-api-key"

# -------------------------------------------------------------------------
# 2. Relational Database (PostgreSQL / Cloud SQL / Supabase SQL)
# -------------------------------------------------------------------------
# Description: Connection parameters used by Drizzle ORM to persist player
#              profiles, game rooms, active matchmaking, tournament brackets,
#              transactions, and live game chat. If unconfigured, the server
#              safely falls back to a temporary, synchronized in-memory database.
# Mandatory: Optional (has memory-fallback, but required for persistent multiplayer)
SQL_HOST="your-database-host"
SQL_USER="your-database-username"
SQL_PASSWORD="your-database-password"
SQL_DB_NAME="your-database-name"

# Optional credentials for running migrations / schema updates via drizzle-kit
SQL_ADMIN_USER="your-database-admin-username"
SQL_ADMIN_PASSWORD="your-database-admin-password"

# -------------------------------------------------------------------------
# 3. Application Metadata
# -------------------------------------------------------------------------
# Description: The URL where the application or server is hosted.
# Mandatory: Optional (used for self-referential links or absolute API routes if needed)
APP_URL="https://your-domain.vercel.app"
